<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Jasa Video Profesional – Affiliate & Brand</title>
<style>
:root{
  --navy:#1A1A2E;--red:#E94560;--gold:#F5A623;
  --purple:#6A1B9A;--green:#2E7D32;
  --light:#F0F4FF;--mid:#D9E4FF;--lgrn:#E8F5E9;--lpurple:#F3E5F5;
  --white:#FFFFFF;--gray:#F7F7F7;--muted:#666;--text:#1A1A2E;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Segoe UI',Arial,sans-serif;background:var(--navy);color:var(--text);line-height:1.6}

/* ── PAGE SYSTEM ── */
.page{display:none;min-height:100vh}
.page.active{display:block}

/* ── BTN ── */
.btn{display:inline-flex;align-items:center;gap:6px;padding:11px 22px;border-radius:8px;
  font-weight:700;font-size:.88rem;text-decoration:none;cursor:pointer;border:none;
  transition:transform .15s,box-shadow .15s;}
.btn:active{transform:scale(.97)}
.btn-red{background:var(--red);color:#fff;box-shadow:0 4px 18px rgba(233,69,96,.35)}
.btn-red:hover{box-shadow:0 6px 24px rgba(233,69,96,.5)}
.btn-outline{background:transparent;border:1.5px solid rgba(255,255,255,.35);color:#fff}
.btn-outline:hover{border-color:var(--gold);color:var(--gold)}
.btn-gold{background:var(--gold);color:var(--navy);box-shadow:0 4px 18px rgba(245,166,35,.3)}
.btn-green{background:#25D366;color:#fff;box-shadow:0 4px 18px rgba(37,211,102,.3)}
.btn-purple{background:var(--purple);color:#fff;box-shadow:0 4px 18px rgba(106,27,154,.35)}
.btn-navy{background:var(--navy);color:#fff;border:1.5px solid rgba(255,255,255,.2)}

/* ── HERO ── */
.hero{background:var(--navy);padding:48px 20px 36px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 70% 60% at 50% 0%,rgba(233,69,96,.18) 0%,transparent 70%);
  pointer-events:none}
.hero-badge{display:inline-block;background:rgba(245,166,35,.15);border:1px solid var(--gold);
  color:var(--gold);font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;
  padding:4px 14px;border-radius:20px;margin-bottom:16px}
.hero h1{font-size:clamp(1.5rem,5vw,2.4rem);font-weight:800;color:var(--white);
  line-height:1.15;margin-bottom:10px}
.hero h1 span{color:var(--red)}
.hero-sub{color:var(--gold);font-size:.92rem;opacity:.9;margin-bottom:6px;letter-spacing:.04em}
.hero-cats{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin:14px 0 24px}
.hero-cat{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.18);
  color:rgba(255,255,255,.8);font-size:.75rem;padding:4px 12px;border-radius:20px}
.hero-btns{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}

/* ── LANDING CHOOSE ── */
.choose-wrap{padding:20px 18px 40px;display:flex;flex-direction:column;gap:14px}
.choose-card{border-radius:16px;overflow:hidden;text-decoration:none;
  display:flex;align-items:center;gap:14px;padding:20px 18px;
  transition:transform .15s,box-shadow .15s;cursor:pointer;border:none;width:100%;text-align:left}
.choose-card:active{transform:scale(.98)}
.choose-card-affiliate{background:linear-gradient(135deg,var(--red),#c0392b);
  box-shadow:0 6px 24px rgba(233,69,96,.35)}
.choose-card-brand{background:linear-gradient(135deg,var(--purple),#4a0080);
  box-shadow:0 6px 24px rgba(106,27,154,.35)}
.choose-icon{font-size:2.2rem;flex-shrink:0}
.choose-txt h3{font-size:1rem;font-weight:800;color:#fff;margin-bottom:3px}
.choose-txt p{font-size:.77rem;color:rgba(255,255,255,.75);line-height:1.4}
.choose-arrow{margin-left:auto;font-size:1.3rem;color:rgba(255,255,255,.5);flex-shrink:0}

/* ── NOTICE ── */
.notice{background:rgba(245,166,35,.1);border:1px solid rgba(245,166,35,.4);
  border-left:4px solid var(--gold);padding:12px 16px;border-radius:0 8px 8px 0;
  font-size:.82rem;color:rgba(255,255,255,.85);text-align:left;max-width:600px;margin:0 auto}
.notice strong{color:var(--gold)}

/* ── WRAP ── */
.wrap{background:var(--white);border-radius:20px 20px 0 0;margin-top:28px;padding:28px 18px 40px}

/* ── BACK BTN ── */
.back-btn{display:flex;align-items:center;gap:6px;font-size:.8rem;font-weight:600;
  color:rgba(255,255,255,.7);background:none;border:none;cursor:pointer;
  padding:12px 20px 0;text-decoration:none}
.back-btn:hover{color:var(--gold)}

/* ── SEC TITLE ── */
.sec-title{text-align:center;margin-bottom:20px}
.sec-title h2{font-size:1.15rem;font-weight:800;color:var(--navy);letter-spacing:-.01em}
.sec-title p{font-size:.8rem;color:var(--muted);margin-top:4px}
.divider{height:3px;border-radius:2px;margin:6px auto 0;width:40px}
.divider.red{background:var(--red)}
.divider.purple{background:var(--purple)}
.divider.gold{background:var(--gold)}
.divider.green{background:var(--green)}

/* ── CARDS ── */
.cards{display:flex;flex-direction:column;gap:16px;margin-bottom:32px}
.card{border-radius:14px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,.08)}
.card-head{padding:14px 18px;display:flex;align-items:center;gap:10px}
.card-head .badge{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;
  justify-content:center;font-size:1rem;background:rgba(255,255,255,.18);flex-shrink:0}
.card-head h3{font-size:.97rem;font-weight:800;color:#fff;line-height:1.25}
.card-head .price{margin-left:auto;text-align:right;font-size:1.4rem;font-weight:900;
  color:#fff;line-height:1}
.card-head .price small{display:block;font-size:.62rem;font-weight:500;opacity:.75;text-transform:uppercase}
.card-body{padding:14px 18px;background:#fff}
.card-desc{font-size:.82rem;color:var(--muted);margin-bottom:12px;line-height:1.5}
.feat-list{display:flex;flex-direction:column;gap:6px;margin-bottom:14px}
.feat{display:flex;align-items:flex-start;gap:8px;font-size:.8rem;color:var(--text)}
.feat .ico{width:18px;height:18px;border-radius:50%;display:flex;align-items:center;
  justify-content:center;font-size:.62rem;flex-shrink:0;margin-top:1px}
.ico-y{background:#dcf8e8;color:var(--green)}
.ico-n{background:#fde8ec;color:var(--red)}
.card-foot{display:flex;align-items:center;justify-content:space-between;
  padding:10px 18px 14px;background:#fff;border-top:1px solid rgba(0,0,0,.06);flex-wrap:wrap;gap:8px}
.min-order{font-size:.75rem;color:var(--muted)}
.min-order strong{color:var(--text)}
.card-p1 .card-head{background:var(--red)}
.card-p2 .card-head{background:var(--navy)}
.card-p3 .card-head{background:var(--purple)}
.card-p3{box-shadow:0 4px 24px rgba(106,27,154,.18)}
.best-badge{display:inline-block;background:var(--gold);color:var(--navy);
  font-size:.6rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase;
  padding:2px 8px;border-radius:10px;margin-left:6px;vertical-align:middle}
.card-p3 .card-head{position:relative}
.card-p3 .card-head::after{content:'⭐ TERLENGKAP';position:absolute;right:14px;top:14px;
  background:var(--gold);color:var(--navy);font-size:.58rem;font-weight:800;
  letter-spacing:.06em;padding:2px 8px;border-radius:10px}

/* ── COMPARE ── */
.compare-wrap{overflow-x:auto;margin-bottom:32px;border-radius:12px;box-shadow:0 2px 16px rgba(0,0,0,.07)}
table{width:100%;border-collapse:collapse;min-width:320px}
thead tr th{padding:10px;font-size:.75rem;font-weight:700;text-align:center}
thead th:first-child{text-align:left;background:var(--navy);color:#fff;border-radius:12px 0 0 0}
thead th:nth-child(2){background:var(--red);color:#fff}
thead th:nth-child(3){background:var(--green);color:#fff}
thead th:last-child{background:var(--purple);color:#fff;border-radius:0 12px 0 0}
tbody tr td{padding:9px 10px;font-size:.78rem;text-align:center;border-bottom:1px solid #f0f0f0}
tbody tr td:first-child{text-align:left;font-weight:600;color:var(--navy)}
tbody tr:nth-child(even) td{background:#fafafa}
tbody tr:last-child td{border-bottom:none}
.yes{color:var(--green);font-weight:700}
.no{color:#ccc}
.hi{color:var(--purple);font-weight:700}

/* ── KETENTUAN ── */
.ket-list{display:flex;flex-direction:column;gap:10px;margin-bottom:32px}
.ket-item{display:flex;gap:12px;align-items:flex-start;
  background:var(--gray);border-radius:10px;padding:12px 14px}
.ket-ico{font-size:1.1rem;flex-shrink:0;margin-top:1px}
.ket-item h4{font-size:.82rem;font-weight:700;color:var(--navy);margin-bottom:2px}
.ket-item p{font-size:.77rem;color:var(--muted);line-height:1.5}

/* ── ORDER FORM ── */
.order-box{background:linear-gradient(135deg,var(--navy) 0%,#2a1a3e 100%);
  border-radius:16px;padding:24px 18px;margin-bottom:28px}
.order-box h2{font-size:1.05rem;font-weight:800;color:#fff;margin-bottom:4px}
.order-box p{font-size:.8rem;color:rgba(255,255,255,.65);margin-bottom:18px}
.form-group{margin-bottom:13px}
.form-group label{display:block;font-size:.75rem;font-weight:600;
  color:rgba(255,255,255,.75);margin-bottom:5px}
.form-group input,.form-group select,.form-group textarea{
  width:100%;padding:11px 13px;border-radius:8px;
  border:1.5px solid rgba(255,255,255,.12);background:rgba(255,255,255,.07);
  color:#fff;font-size:.85rem;font-family:inherit;outline:none;transition:border .2s;-webkit-appearance:none}
.form-group select option{background:var(--navy);color:#fff}
.form-group input::placeholder,.form-group textarea::placeholder{color:rgba(255,255,255,.35)}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--gold)}
.form-group textarea{resize:vertical;min-height:80px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
@media(max-width:380px){.form-row{grid-template-columns:1fr}}
.qty-wrap{display:flex;align-items:center;gap:0}
.qty-btn{width:40px;height:42px;border:1.5px solid rgba(255,255,255,.18);
  background:rgba(255,255,255,.07);color:#fff;font-size:1.1rem;
  cursor:pointer;border-radius:8px 0 0 8px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center}
.qty-btn:last-child{border-radius:0 8px 8px 0}
.qty-input{flex:1;text-align:center;border-left:none!important;border-right:none!important;border-radius:0!important}
.total-box{background:rgba(245,166,35,.12);border:1px solid rgba(245,166,35,.3);
  border-radius:10px;padding:12px 14px;margin:14px 0;
  display:flex;justify-content:space-between;align-items:center}
.total-box span{font-size:.8rem;color:rgba(255,255,255,.75)}
.total-box strong{font-size:1.15rem;font-weight:900;color:var(--gold)}
.form-btn{width:100%;padding:14px;border-radius:10px;background:#25D366;color:#fff;border:none;
  font-size:.95rem;font-weight:800;cursor:pointer;display:flex;align-items:center;
  justify-content:center;gap:8px;transition:opacity .2s;letter-spacing:.01em}
.form-btn:hover{opacity:.92}
.form-btn:active{transform:scale(.98)}

/* ── MULTI PAKET ROWS ── */
.paket-row{background:rgba(255,255,255,.06);border:1.5px solid rgba(255,255,255,.1);
  border-radius:10px;padding:10px 12px;margin-bottom:8px;transition:border .2s,background .2s}
.paket-row.active{background:rgba(255,255,255,.11);border-color:var(--gold)}
.paket-check{display:flex;align-items:center;gap:10px}
.paket-check input[type="checkbox"]{width:18px;height:18px;flex-shrink:0;accent-color:var(--gold);cursor:pointer}
.paket-label{display:flex;align-items:center;gap:10px;cursor:pointer;flex:1}
.paket-dot{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;
  justify-content:center;font-size:.78rem;font-weight:800;color:#fff;flex-shrink:0}
.paket-info{display:flex;flex-direction:column;line-height:1.2}
.paket-info strong{font-size:.82rem;color:#fff}
.paket-info small{font-size:.7rem;color:rgba(255,255,255,.5);margin-top:1px}
.paket-qty{display:flex;align-items:center;gap:0;margin-top:8px;padding-top:8px;
  border-top:1px solid rgba(255,255,255,.1)}
.paket-qty .qty-btn{width:36px;height:36px;font-size:1rem}
.paket-qty .qty-input{height:36px;font-size:.85rem}

/* ── BAYAR OPTIONS ── */
.bayar-opts{display:flex;flex-direction:column;gap:8px}
.bayar-opt{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,.06);
  border:1.5px solid rgba(255,255,255,.1);border-radius:10px;padding:10px 12px;
  cursor:pointer;transition:border .2s,background .2s}
.bayar-opt input[type="radio"]{width:16px;height:16px;flex-shrink:0;accent-color:var(--gold);cursor:pointer}
.bayar-opt:has(input:checked){background:rgba(245,166,35,.12);border-color:var(--gold)}
.bayar-icon{font-size:1.2rem;flex-shrink:0}
.bayar-txt{display:flex;flex-direction:column;line-height:1.2}
.bayar-txt strong{font-size:.85rem;color:#fff}
.bayar-txt small{font-size:.72rem;color:rgba(255,255,255,.5)}

/* ── WA SECTION ── */
.wa-section{background:var(--gray);border-radius:16px;padding:20px 18px;
  margin-bottom:20px;text-align:center}
.wa-section h3{font-size:.95rem;font-weight:800;color:var(--navy);margin-bottom:4px}
.wa-section p{font-size:.78rem;color:var(--muted);margin-bottom:14px}
.wa-btns{display:flex;flex-direction:column;gap:10px}
.wa-btn{display:flex;align-items:center;gap:10px;padding:13px 16px;border-radius:10px;
  text-decoration:none;font-weight:700;font-size:.85rem;transition:transform .15s,box-shadow .15s}
.wa-btn:active{transform:scale(.97)}
.wa-btn-chat{background:#25D366;color:#fff;box-shadow:0 4px 16px rgba(37,211,102,.25)}
.wa-btn-grup{background:var(--purple);color:#fff;box-shadow:0 4px 16px rgba(106,27,154,.25)}
.wa-btn .wa-ico{width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,.2);
  display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
.wa-btn .wa-txt{text-align:left}
.wa-btn .wa-txt small{display:block;font-size:.68rem;font-weight:400;opacity:.85;margin-top:1px}

/* ── TESTIMONI ── */
.testi-wrap{margin-bottom:32px}
.testi-scroll{display:flex;gap:10px;overflow-x:auto;padding-bottom:10px;
  scrollbar-width:none;-ms-overflow-style:none}
.testi-scroll::-webkit-scrollbar{display:none}
.testi-item{flex-shrink:0;width:120px;border-radius:12px;overflow:hidden;
  box-shadow:0 3px 14px rgba(0,0,0,.15);cursor:pointer;
  transition:transform .2s;position:relative}
.testi-item:active{transform:scale(.96)}
.testi-item img{width:100%;height:200px;object-fit:cover;display:block}
.testi-item .testi-overlay{position:absolute;bottom:0;left:0;right:0;
  background:linear-gradient(transparent,rgba(0,0,0,.55));
  padding:18px 6px 6px;text-align:center}
.testi-item .testi-overlay span{font-size:.62rem;color:#fff;font-weight:600}

/* LIGHTBOX */
.lightbox{display:none;position:fixed;inset:0;z-index:9999;
  background:rgba(0,0,0,.92);align-items:center;justify-content:center}
.lightbox.open{display:flex}
.lightbox img{max-width:92vw;max-height:88vh;border-radius:12px;object-fit:contain}
.lightbox-close{position:absolute;top:16px;right:20px;font-size:1.8rem;
  color:#fff;cursor:pointer;font-weight:300;line-height:1;background:none;border:none}

/* ── FOOTER ── */
.footer{text-align:center;padding:20px 18px 32px;
  font-size:.72rem;color:rgba(255,255,255,.35);background:var(--navy)}
.footer strong{color:rgba(255,255,255,.55)}

/* ── STICKY BAR ── */
.sticky-bar{position:fixed;bottom:0;left:0;right:0;background:var(--navy);
  border-top:1px solid rgba(255,255,255,.1);padding:10px 18px 14px;
  display:flex;gap:10px;z-index:999}
.sticky-bar a,.sticky-bar button{flex:1}

/* ── BACKGROUND MUSIC ── */
let musicPlaying = false;
let musicStarted = false;
const bgm = document.getElementById('bgm');
bgm.volume = 0.35;

function startMusicOnce() {
  if (musicStarted) return;
  musicStarted = true;
  bgm.play().then(() => {
    musicPlaying = true;
    document.getElementById('music-btn').textContent = '🎵';
    document.getElementById('music-btn').style.borderColor = 'var(--gold)';
  }).catch(() => {
    // autoplay blocked — wait for user interaction
    musicStarted = false;
  });
}

function toggleMusic() {
  if (!musicStarted || bgm.paused) {
    bgm.play().then(() => {
      musicPlaying = true;
      musicStarted = true;
      document.getElementById('music-btn').textContent = '🎵';
      document.getElementById('music-btn').style.borderColor = 'var(--gold)';
    });
  } else {
    bgm.pause();
    musicPlaying = false;
    document.getElementById('music-btn').textContent = '🔇';
    document.getElementById('music-btn').style.borderColor = 'rgba(255,255,255,.2)';
  }
}

// Try autoplay on every user interaction — covers iOS & Android
const evts = ['touchstart','touchend','click','scroll','keydown','pointerdown'];
function onFirstInteraction() {
  startMusicOnce();
  evts.forEach(e => document.removeEventListener(e, onFirstInteraction));
}
evts.forEach(e => document.addEventListener(e, onFirstInteraction, {once:false, passive:true}));

// Also try immediately (works on desktop)
setTimeout(() => { if (!musicStarted) startMusicOnce(); }, 500);

/* ── FADE IN ── */
.fade-in{opacity:0;transform:translateY(18px);transition:opacity .45s,transform .45s}
.fade-in.visible{opacity:1;transform:none}

@media(min-width:600px){
  .wrap{padding:32px 28px 48px;border-radius:24px 24px 0 0}
  .hero{padding:64px 28px 40px}
}
@media(min-width:800px){
  body{max-width:480px;margin:0 auto;position:relative}
  .sticky-bar{max-width:480px;left:50%;transform:translateX(-50%)}
}
</style>
</head>
<body>

<!-- ── BACKGROUND MUSIC ─────────────────────────────────────── -->
<audio id="bgm" loop preload="auto" style="display:none">
  <source src="data:audio/mpeg;base64,
